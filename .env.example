CONTROL_PANEL_MOCK=true
WEB_CONTROL_PASSWORD=replace-with-control-panel-password
SESSION_SECRET=replace-with-a-long-random-string

GCP_PROJECT_ID=your-gcp-project-id
GCP_ZONE=asia-northeast3-a
GCP_INSTANCE_NAME=palworld-server
PALWORLD_MACHINE_TYPE_LOW=e2-highmem-2
PALWORLD_MACHINE_TYPE_NORMAL=e2-highmem-4

PALWORLD_REST_BASE_URL=http://VM내부IP:8212/v1/api
PALWORLD_ADMIN_USERNAME=admin
PALWORLD_ADMIN_PASSWORD=replace-with-palworld-admin-password

FIRESTORE_STATE_COLLECTION=serverControl
FIRESTORE_STATE_DOCUMENT=palworld

AUTOSTOP_ENABLED_DEFAULT=true
AUTOSTOP_SECRET=replace-with-scheduler-shared-secret
AUTOSTOP_OIDC_AUDIENCE=
AUTOSTOP_SCHEDULER_SERVICE_ACCOUNT=
AUTOSTOP_GRACE_MINUTES=20
AUTOSTOP_EMPTY_MINUTES=10
PALWORLD_STATUS_TIMEOUT_MS=5000
PALWORLD_PLAYERS_TIMEOUT_MS=8000
PALWORLD_SAVE_TIMEOUT_MS=60000
PALWORLD_SHUTDOWN_TIMEOUT_MS=60000
PALWORLD_SHUTDOWN_WAIT_SECONDS=120
COMPUTE_OPERATION_TIMEOUT_MS=180000
COMPUTE_OPERATION_POLL_INTERVAL_MS=2000
CONTROL_OPERATION_LOCK_TIMEOUT_MS=600000
